# OpenAI
OPENAI_API_KEY=sk-...

# News (only needed to run scripts/fetch_and_freeze.py once)
NEWSAPI_KEY=your_key_here        # newsapi.org — free tier, 100 req/day

# App Config
ENV=development
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
MAX_ARTICLES_PER_FETCH=50
CHUNK_SIZE_TOKENS=300
CHUNK_OVERLAP_TOKENS=50
TOP_K_RETRIEVAL=5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=400
